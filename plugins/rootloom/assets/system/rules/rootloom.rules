# rootloom:managed version=1
# Codex command rules are experimental. Test every change with:
# codex execpolicy check --pretty --rules <this-file> -- <command...>
#
# Rules primarily govern requests to run outside the sandbox; Hooks and
# sandboxing remain necessary defense in depth. Rules cannot represent the
# persistent Standard plus task-local Single action and Full authorization
# modes. `allow` prevents a duplicate command prompt but never grants task authority.
# Only catastrophic recursive deletion remains a static hard deny.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "allow",
    justification = "Hard reset is high risk and must be covered by Single action or Full task authorization; Rules do not carry that authorization state.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
)

# Inspection is still possible with `git clean --dry-run`; forced deletion is blocked.
prefix_rule(
    pattern = ["git", "clean"],
    decision = "allow",
    justification = "Targeted git clean inspection or execution is allowed only when the current user request authorizes the exact scope; forced bulk deletion remains forbidden below.",
    match = [
        "git clean --dry-run",
        "git clean -n",
        "git clean -fd",
    ],
)

prefix_rule(
    pattern = ["git", "clean", ["-f", "-fd", "-df", "-fdx", "-xdf", "-fxd", "--force"]],
    decision = "allow",
    justification = "Forced clean is high risk and must be covered by Single action or Full task authorization for the reviewed scope.",
    match = [
        "git clean -f",
        "git clean -fd",
        "git clean -fdx",
        "git clean --force",
    ],
    not_match = [
        "git clean --dry-run",
        "git clean -n",
    ],
)

prefix_rule(
    pattern = ["git", "checkout", "--"],
    decision = "allow",
    justification = "Checkout restoration must be covered by the active task-local authorization mode; Rules do not prompt a second time.",
    match = [
        "git checkout -- src/app.ts",
        "git checkout -- .",
    ],
)

prefix_rule(
    pattern = ["git", "checkout", "--", [".", "/", "*", ":(top)"]],
    decision = "allow",
    justification = "Bulk checkout restoration is high risk and must be covered by Single action or Full task authorization.",
    match = [
        "git checkout -- .",
        "git checkout -- *",
    ],
)

prefix_rule(
    pattern = ["git", "restore"],
    decision = "allow",
    justification = "Restoration must be covered by the active task-local authorization mode; Rules do not prompt a second time.",
    match = [
        "git restore src/app.ts",
        "git restore .",
    ],
)

prefix_rule(
    pattern = ["git", "restore", [".", "/", "*", ":(top)"]],
    decision = "allow",
    justification = "Bulk restoration is high risk and must be covered by Single action or Full task authorization.",
    match = [
        "git restore .",
        "git restore *",
    ],
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "allow",
    justification = "Local commits are reversible repository history and are allowed. Remote publication remains governed separately by git push rules.",
    match = [
        "git commit -m test",
        "git commit --amend",
        "git commit --allow-empty -m checkpoint",
    ],
)

prefix_rule(
    pattern = ["git", "push", ["--force", "-f", "--force-with-lease", "--force-if-includes", "--mirror", "--delete", "--prune"]],
    decision = "allow",
    justification = "Force, mirror, deletion, and pruning pushes are high risk and must be covered by Single action or Full task authorization for the exact remote and refs.",
    match = [
        "git push --force origin main",
        "git push --force-with-lease",
        "git push --delete origin old-branch",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "allow",
    justification = "Ordinary push is allowed inside an authorized code-publication type and its scoped repository, branches, and tags; Rules do not supply that authority.",
    match = [
        "git push",
        "git push origin main",
        "git push origin v2.3.0",
    ],
)

# Catastrophic recursive deletions. Multiple common flag arrangements are listed
# because prefix rules match argv positions exactly.
prefix_rule(
    pattern = ["rm", ["-rf", "-fr"], ["/", ".", "..", "~", "$HOME", "/*"]],
    decision = "forbidden",
    justification = "Refuse recursive forced deletion of root, home, the current directory, or its parent. Delete only reviewed paths.",
    match = [
        "rm -rf /",
        "rm -rf .",
        "rm -fr ..",
    ],
)

prefix_rule(
    pattern = ["rm", ["-r", "--recursive"], ["-f", "--force"], ["/", ".", "..", "~", "$HOME", "/*"]],
    decision = "forbidden",
    justification = "Refuse recursive forced deletion of root, home, the current directory, or its parent.",
    match = [
        "rm -r -f /",
        "rm --recursive --force .",
    ],
)

prefix_rule(
    pattern = ["rm", ["-f", "--force"], ["-r", "--recursive"], ["/", ".", "..", "~", "$HOME", "/*"]],
    decision = "forbidden",
    justification = "Refuse recursive forced deletion of root, home, the current directory, or its parent.",
    match = [
        "rm -f -r /",
        "rm --force --recursive ..",
    ],
)

prefix_rule(
    pattern = [["npm", "pnpm", "cargo"], "publish"],
    decision = "allow",
    justification = "Package publication is allowed inside an authorized package-publication type and its scoped registry, package, version, and channel.",
    match = [
        "npm publish",
        "pnpm publish",
        "cargo publish",
    ],
)

prefix_rule(
    pattern = ["yarn", "npm", "publish"],
    decision = "allow",
    justification = "Package publication is allowed inside an authorized package-publication type and its scoped registry, package, version, and channel.",
    match = ["yarn npm publish"],
)

prefix_rule(
    pattern = ["twine", "upload"],
    decision = "allow",
    justification = "Python distribution upload is allowed inside an authorized package-publication type and its scoped repository, artifacts, version, and channel.",
    match = ["twine upload dist/package.whl"],
)

prefix_rule(
    pattern = ["docker", "push"],
    decision = "allow",
    justification = "Image push is allowed inside an authorized image-publication or deployment type and its scoped registry, repository, and tag or digest.",
    match = ["docker push example/app:latest"],
)

prefix_rule(
    pattern = ["kubectl", ["apply", "replace", "patch"]],
    decision = "allow",
    justification = "Routine cluster rollout is allowed inside an authorized deployment type and its scoped cluster, namespace, and targets.",
    match = [
        "kubectl apply -f deployment.yaml",
        "kubectl patch deployment app --patch-file patch.json",
    ],
)

prefix_rule(
    pattern = ["kubectl", "delete"],
    decision = "allow",
    justification = "Cluster deletion is high risk and must be covered by Single action or Full task authorization for the exact cluster, namespace, and resources.",
    match = ["kubectl delete pod app-1"],
)

prefix_rule(
    pattern = ["helm", ["install", "upgrade", "rollback"]],
    decision = "allow",
    justification = "Routine Helm rollout is allowed inside an authorized deployment type and its scoped environment and release.",
    match = [
        "helm upgrade app ./chart",
        "helm rollback app 2",
    ],
)

prefix_rule(
    pattern = ["helm", "uninstall"],
    decision = "allow",
    justification = "Helm uninstall is high risk and must be covered by Single action or Full task authorization for the exact environment and release.",
    match = ["helm uninstall app"],
)

prefix_rule(
    pattern = ["terraform", ["apply", "import"]],
    decision = "allow",
    justification = "Terraform apply or import is allowed inside an authorized infrastructure-change type and its scoped workspace and reviewed targets.",
    match = [
        "terraform apply",
        "terraform import module.app.example_resource.main resource-id",
    ],
)

prefix_rule(
    pattern = ["terraform", "destroy"],
    decision = "allow",
    justification = "Terraform destroy is high risk and must be covered by Single action or Full task authorization for the exact workspace and targets.",
    match = ["terraform destroy -auto-approve"],
)

prefix_rule(
    pattern = ["pulumi", ["up", "import"]],
    decision = "allow",
    justification = "Pulumi update or import is allowed inside an authorized infrastructure-change type and its scoped organization, project, stack, and targets.",
    match = [
        "pulumi up",
        "pulumi import example:index:Resource name resource-id",
    ],
)

prefix_rule(
    pattern = ["pulumi", "destroy"],
    decision = "allow",
    justification = "Pulumi destroy is high risk and must be covered by Single action or Full task authorization for the exact organization, project, stack, and targets.",
    match = ["pulumi destroy"],
)

prefix_rule(
    pattern = ["gh", "pr", ["create", "merge"]],
    decision = "allow",
    justification = "Pull-request creation or merge is allowed inside an authorized code-publication type and its scoped repository and change set.",
    match = [
        "gh pr create --title release",
        "gh pr merge 123 --merge",
    ],
)

prefix_rule(
    pattern = ["gh", "release", "create"],
    decision = "allow",
    justification = "Release creation is allowed inside an authorized code-publication type and its scoped repository, tag, version, and release channel.",
    match = ["gh release create v1.0.0"],
)

prefix_rule(
    pattern = ["gh", "release", "delete"],
    decision = "allow",
    justification = "Release deletion is high risk and must be covered by Single action or Full task authorization for the exact repository and tag.",
    match = ["gh release delete v1.0.0"],
)
